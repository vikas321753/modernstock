{
  "version": 2,
  "builds": [
    {
      "src": "api/stock.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/stock",
      "dest": "api/stock.js"
    },
    {
      "src": "/(index.html)?",
      "dest": "/index.html"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    }
  ]
}
